{
  "name": "primusneo",
  "web": {
    "service": {
      "containerName": "primusneo-web",
      "image": "primusneo:latest",
      "ports": ["3000"],
      "env": {
        "NODE_ENV": "production",
        "NEXT_PUBLIC_APP_URL": "https://primusneo.railway.app",
        "DATABASE_URL": "${RAILWAY_DATABASE_URL}",
        "NEXTAUTH_SECRET": "${NEXTAUTH_SECRET}",
        "NEXTAUTH_URL": "https://primusneo.railway.app",
        "AUTH_SECRET": "${AUTH_SECRET}",
        "AUTH_DISCORD_ID": "${AUTH_DISCORD_ID}",
        "AUTH_DISCORD_SECRET": "${AUTH_DISCORD_SECRET}"
      }
    }
  }
}